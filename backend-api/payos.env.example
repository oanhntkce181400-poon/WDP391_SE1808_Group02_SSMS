# PayOS Configuration
# Đăng ký tài khoản PayOS tại https://payos.vn để lấy các thông tin bên dưới

# Client ID từ PayOS Dashboard
PAYC_CLIENT_ID=your_client_id_here

# API Key từ PayOS Dashboard
PAYC_API_KEY=your_api_key_here

# Checksum Key từ PayOS Dashboard
PAYC_CHECKSUM_KEY=your_checksum_key_here

# URL webhook để nhận thông báo thanh toán (phải là HTTPS)
# Ví dụ: https://yourdomain.com/api/payment/webhook
PAYC_WEBHOOK_URL=https://yourdomain.com/api/payment/webhook
